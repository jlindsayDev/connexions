        "explorer.excludeGitIgnore": true,
        "editor.formatOnSave": true
    },
    "extensions": {
        "recommendations": [
            "oven.bun-vscode",
            "ms-vscode.vscode-typescript-next",
            "biomejs.biome"
        ]
    }
}

// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/marcosgomesneto/bun-devcontainers/tree/main/src/bun-mariadb
{
    "$schema": "https://raw.githubusercontent.com/microsoft/vscode/main/extensions/configuration-editing/schemas/devContainer.vscode.schema.json",
    "name": "Connexions",
    "dockerFile": "Dockerfile",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    // Features to add to the dev container. More info: https://containers.dev/features.
    // "features": {},
    // Use 'forwardPorts' to make a list of ports inside the container available locally.
    // "forwardPorts": [5173, 5820],
    // "portsAttributes": {},
    // Use 'postCreateCommand' to run commands after the container is created.
    "postCreateCommand": "bun install",
    // Configure tool-specific properties.
    "customizations": {
        "typescript.experimental.useTsgo": true,
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "typescript.tsdk": "node_modules/typescript/lib",
        "extensions": [],
        "vscode": {
            "settings": {
                "editor.defaultFormatter": "biomejs.biome",
                "editor.codeActionsOnSave": {
                    "source.organizeImports.biome": "explicit",
                    "source.organizeImports": "explicit",
                    "source.biome": "explicit",
                    "source.fixAll.biome": "explicit"
                },
                "editor.formatOnSave": false
            },
            "extensions": [
                "oven.bun-vscode",
                "ms-vscode.vscode-typescript-next",
                "biomejs.biome",
                "TypeScriptTeam.native-preview"
            ]
        }
    }
    // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
    // "remoteUser": "root"
}
